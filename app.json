{
  "expo": {
    "scheme": "alba",
    "name": "Alba",
    "slug": "alba-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/AlbaAppLogoSemFundo.png",
    "splash": {
      "image": "./assets/AlbaAppLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "userInterfaceStyle": "automatic",
    "web": {
      "bundler": "metro"
    },
    "ios": {
      "supportsTablet": false,
      "icon": "./assets/AlbaAppLogoSemFundo.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "A Alba precisa da tua localização para mostrar profissionais de saúde próximos de ti."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/AlbaAppLogoSemFundo.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.anonymous.albaapp"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "A Alba precisa da tua localização para mostrar profissionais de saúde próximos de ti."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/AlbaAppLogoSemFundo.png",
          "color": "#6366f1",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker",
      "@rnmapbox/maps"
    ]
  }
}
