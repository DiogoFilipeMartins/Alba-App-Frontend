{
  "expo": {
    "scheme": "alba",
    "name": "alba-app",
    "slug": "alba-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "assetBundlePatterns": [
      "**/*"
    ],
    "userInterfaceStyle": "automatic",
    "web": {
      "bundler": "metro"
    },
    "ios": {
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "A Alba precisa da tua localização para mostrar profissionais de saúde próximos de ti."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY_HERE"
        }
      },
      "package": "com.anonymous.albaapp"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "A Alba precisa da tua localização para mostrar profissionais de saúde próximos de ti."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366f1",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
